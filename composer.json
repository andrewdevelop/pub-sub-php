{
  "name": "andrewdevelop/pub-sub",
  "type": "package",
  "require-dev": {
    "phpoption/phpoption": "^1.9",
    "phpunit/phpunit": "^10.5",
    "vlucas/phpdotenv": "^5.6"
  },
  "require": {
    "php": "^8.1|^8.2",
    "php-amqplib/php-amqplib": "v3.7.4",
    "andrewdevelop/event-sourcing": "^2.0",
    "andrewdevelop/hex-contracts": "^2.0",
    "illuminate/container": "^9.0|^10.0",
    "illuminate/console": "^9.0|^10.0",
    "illuminate/config": "^9.0|^10.0",
    "ramsey/uuid": "^4.7",
    "psr/log": "^1.1",
    "ext-pcntl": "*",
    "ext-json": "*"
  },
  "autoload": {
    "psr-4": {
      "Core\\Messaging\\": "src/"
    }
  },
  "config": {
    "preferred-install": "dist",
    "sort-packages": true,
    "optimize-autoloader": true
  }
}
